---
layout: layouts/base.njk
title: Monthly update
description: A plain-English summary of what changed in the latest monthly public finances release, and why.
eleventyComputed:
  canonicalUrl: "{{ site.url }}/monthly/{{ monthlyUpdates.updates[0].id }}/"
---
{% from "components/macros.njk" import monthlyBody, dataFreshnessBadge %}

{% set u = monthlyUpdates.updates[0] %}

<div class="page-intro prose">
  <h1>Monthly update: {{ u.month }}</h1>
  <p class="lede">{{ u.headline }}</p>
  <p class="updated">Released {{ u.published | readableDate }}. {{ dataFreshnessBadge(u.confidence_level, "") }}</p>
</div>

{{ monthlyBody(u, monthlyQuestions.questions) }}

<p class="prose"><a href="{{ ('/monthly/' + u.id + '/') | url }}">Permanent link to the {{ u.month }} update</a></p>

{% if monthlyUpdates.updates.length > 1 %}
<section class="prose" aria-labelledby="archive-heading">
  <h2 id="archive-heading">Earlier updates</h2>
  <ul>
    {%- for past in monthlyUpdates.updates %}
    {%- if not loop.first %}
    <li><a href="{{ ('/monthly/' + past.id + '/') | url }}">{{ past.month }}</a>: {{ past.headline }}</li>
    {%- endif %}
    {%- endfor %}
  </ul>
</section>
{% endif %}
