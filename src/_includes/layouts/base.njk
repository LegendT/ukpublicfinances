<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#123a51">
  <link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
  <link rel="icon" href="{{ '/assets/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="apple-touch-icon" href="{{ '/assets/apple-touch-icon.png' | url }}">
  <link rel="manifest" href="{{ '/site.webmanifest' | url }}">
  {%- set pageTitle = (title + " — " + site.title) if title else site.title %}
  {%- set pageDesc = description or site.description %}
  {%- set canonical = site.url + page.url %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}">
  <link rel="canonical" href="{{ canonical }}">

  <!-- Open Graph -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="en_GB">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDesc }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ site.url }}{{ site.ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ site.title }} — official data, plain English.">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDesc }}">
  <meta name="twitter:image" content="{{ site.url }}{{ site.ogImage }}">
  <meta name="twitter:image:alt" content="{{ site.title }} — official data, plain English.">

  <link rel="sitemap" type="application/xml" href="{{ '/sitemap.xml' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}">

  <!-- Structured data: who runs this and what it is -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}/",
        "name": {{ site.title | jsonScript | safe }},
        "description": {{ site.description | jsonScript | safe }},
        "inLanguage": "en-GB",
        "publisher": { "@id": "{{ site.url }}/#publisher" }
      },
      {
        "@type": "Organization",
        "@id": "{{ site.url }}/#publisher",
        "name": {{ site.title | jsonScript | safe }},
        "url": "{{ site.url }}/",
        "logo": "{{ site.url }}{{ site.ogImage }}",
        "sameAs": [{{ site.repo | jsonScript | safe }}],
        "founder": { "@type": "Person", "name": {{ site.author | jsonScript | safe }} }
      },
      {
        "@type": "WebPage",
        "@id": "{{ canonical }}#webpage",
        "url": "{{ canonical }}",
        "name": {{ pageTitle | jsonScript | safe }},
        "description": {{ pageDesc | jsonScript | safe }},
        "isPartOf": { "@id": "{{ site.url }}/#website" },
        "inLanguage": "en-GB",
        "dateModified": "{{ page.date | isoDate }}"
      }
    ]
  }
  </script>

  {%- if site.analytics.cloudflareToken %}
  <!-- Cloudflare Web Analytics — privacy-friendly, cookieless -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ site.analytics.cloudflareToken }}"}'></script>
  {%- endif %}
</head>
<body{% if pageClass %} class="{{ pageClass }}"{% endif %}>
  <a class="skip-link" href="#main">Skip to main content</a>

  <header class="site-header">
    <div class="wrap site-header__inner">
      <a class="site-header__brand" href="{{ '/' | url }}">{{ site.title }}</a>
      <nav class="site-nav" aria-label="Primary">
        <button class="site-nav__toggle" aria-expanded="false" aria-controls="primary-nav">Menu</button>
        <ul id="primary-nav" class="site-nav__list">
          {%- for item in site.nav %}
            {%- if item.children %}
            <li class="site-nav__group">
              <details class="nav-group{% if item.children | findBy('url', page.url) %} is-active{% endif %}">
                <summary>{{ item.text }}</summary>
                <ul class="nav-group__menu">
                  {%- for child in item.children %}
                  <li><a href="{{ child.url | url }}"{% if page.url == child.url %} aria-current="page"{% endif %}>{{ child.text }}</a></li>
                  {%- endfor %}
                </ul>
              </details>
            </li>
            {%- else %}
            <li>
              <a href="{{ item.url | url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.text }}</a>
            </li>
            {%- endif %}
          {%- endfor %}
        </ul>
      </nav>
    </div>
  </header>

  <main id="main" class="wrap" tabindex="-1">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>{{ site.title }} — an educational project. Figures show their source and date, and may be revised.</p>
      <p class="site-footer__warn">{{ meta.footerNote }}</p>
      <p><a href="{{ '/about/' | url }}">About &amp; methodology</a> · <a href="{{ '/sources/' | url }}">All data sources</a> · <a href="{{ '/glossary/' | url }}">Glossary</a> · <a href="{{ '/privacy/' | url }}">Privacy</a></p>
    </div>
  </footer>

  <script src="{{ '/assets/js/nav.js' | url }}" defer></script>
</body>
</html>
