---
layout: layouts/base.njk
title: Budget simulator
description: A simplified educational model — adjust spending and tax, try to balance the budget, and see the effect on debt.
pageClass: has-sticky-status
---
{% from "components/macros.njk" import caveatBox %}
{% set b = assumptions.budgetSimulator %}

<div class="page-intro prose">
  <h1>Budget simulator</h1>
  <p class="lede">You are Chancellor. Your challenge: <strong>balance the budget</strong> — get borrowing down to zero — by changing spending and tax. Watch the effect on debt over {{ b.projection.years }} years.</p>
</div>

{{ caveatBox(b.disclaimer, "This is a teaching model, not a forecast") }}

<div class="sim-layout">
  <div class="simulator" id="simulator" role="group" aria-label="Budget controls">
    <fieldset class="simulator__group">
      <legend>Spending (£ billion per year)</legend>
      {%- set sp = b.spendingLeversGbpBillion %}
      {%- set sr = b.spendingRange %}
      {%- set labels = { "health": "Health", "education": "Education", "defence": "Defence", "welfare": "Welfare (excl. pension)", "pensions": "State pension" } %}
      {%- for key, base in sp %}
      {%- set min = (base * sr.minFactor) | round(0) %}
      {%- set max = (base * sr.maxFactor) | round(0) %}
      <div class="slider">
        <label for="sp-{{ key }}">{{ labels[key] }} <span class="slider__range">(£{{ min }}–{{ max }} bn)</span></label>
        <input type="range" id="sp-{{ key }}" data-spend="{{ key }}" data-base="{{ base }}"
               min="{{ min }}" max="{{ max }}" step="{{ sr.step }}" value="{{ base }}"
               aria-describedby="sp-{{ key }}-out">
        <output id="sp-{{ key }}-out" for="sp-{{ key }}">£{{ base }} bn</output>
      </div>
      {%- endfor %}
    </fieldset>

    <fieldset class="simulator__group">
      <legend>Tax rates</legend>
      {%- for t in b.taxLevers %}
      <div class="slider">
        <label for="tax-{{ t.id }}">{{ t.label }} <span class="slider__range">({{ t.min }}–{{ t.max }}%, now {{ t.rate }}%)</span></label>
        <input type="range" id="tax-{{ t.id }}" data-tax="{{ t.id }}" data-base="{{ t.rate }}" data-perpoint="{{ t.perPointGbpBillion }}"
               min="{{ t.min }}" max="{{ t.max }}" step="1" value="{{ t.rate }}" aria-describedby="tax-{{ t.id }}-out">
        <output id="tax-{{ t.id }}-out" for="tax-{{ t.id }}">{{ t.rate }}%</output>
      </div>
      {%- endfor %}
    </fieldset>

    <button type="button" class="btn btn--ghost" id="sim-reset">Reset to today</button>
  </div>

  <div class="sim-results">
    <p class="sim-goal" id="sim-status" aria-live="polite">Move the sliders to balance the budget.</p>

    <h2 class="visually-hidden">Result</h2>
    <div class="metric-grid metric-grid--compact">
      <article class="metric-card metric-card--mini"><p class="metric-card__value" id="r-spending">—</p><p class="metric-card__label">Total spending</p></article>
      <article class="metric-card metric-card--mini"><p class="metric-card__value" id="r-revenue">—</p><p class="metric-card__label">Total revenue</p></article>
      <article class="metric-card metric-card--mini"><p class="metric-card__value" id="r-borrowing">—</p><p class="metric-card__label" id="r-borrowing-label">Borrowing this year</p></article>
    </div>

    <h3>Debt over {{ b.projection.years }} years</h3>
    <div class="table-scroll" tabindex="0" role="region" aria-label="Projected debt over five years">
      <table class="data-table">
        <caption>Projected net debt, applying your choices each year. Assumes a {{ (b.projection.assumedInterestRate * 100) | round(0) }}% interest rate and a fixed economy — see assumptions below.</caption>
        <thead><tr><th scope="col">Year</th><th scope="col" class="num">Debt (£ bn)</th><th scope="col" class="num">Debt (% of GDP)</th></tr></thead>
        <tbody id="r-trajectory"></tbody>
      </table>
    </div>
  </div>
</div>

<details class="prose">
  <summary>Assumptions used in this model</summary>
  <ul>
    <li>Baseline spending £{{ b.baselineGbpBillion.totalSpending | number }} bn, revenue £{{ b.baselineGbpBillion.totalRevenue | number }} bn, debt £{{ b.baselineGbpBillion.debt | number }} bn — so today's starting point is a deficit of £{{ b.baselineGbpBillion.borrowing | number }} bn.</li>
    <li>{{ b.taxNote }}</li>
    <li>{{ b.projection.note }}</li>
  </ul>
</details>

<noscript><p class="caveat">This simulator needs JavaScript. The baseline figures are on the <a href="{{ '/' | url }}">dashboard</a>.</p></noscript>

<script id="sim-config" type="application/json">
{
  "baseline": {{ b.baselineGbpBillion | jsonScript | safe }},
  "spendingBase": {{ b.spendingLeversGbpBillion | jsonScript | safe }},
  "projection": {{ b.projection | jsonScript | safe }},
  "gdp": {{ dashboard.supporting.gdp.value }}
}
</script>
<script type="module" src="{{ '/assets/js/budget-simulator.js' | url }}"></script>
