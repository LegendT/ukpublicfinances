---
layout: layouts/base.njk
---
{% from "components/macros.njk" import metricCard, caveatBox, dataFreshnessBadge %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "@id": "{{ site.url }}/#dataset",
  "name": "UK public finances: headline figures",
  "description": "Public sector net debt, borrowing, debt interest and related figures for the UK, plus a long-run debt-to-GDP series, each carrying its own source, date and confidence level. Compiled from ONS, OBR, HMRC and the Bank of England.",
  "url": "{{ site.url }}/",
  "inLanguage": "en-GB",
  "isAccessibleForFree": true,
  "license": "https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/",
  "creator": { "@id": "{{ site.url }}/#publisher" },
  "spatialCoverage": "United Kingdom",
  "temporalCoverage": "1700/..",
  "dateModified": "{{ dashboard.lastUpdated }}",
  "keywords": ["UK national debt", "public sector net debt", "government borrowing", "debt interest", "public finances", "OBR", "ONS"],
  "distribution": [
    {
      "@type": "DataDownload",
      "name": "Headline figures (current)",
      "encodingFormat": "application/json",
      "contentUrl": "https://raw.githubusercontent.com/LegendT/ukpublicfinances/main/src/_data/dashboard.json"
    },
    {
      "@type": "DataDownload",
      "name": "Long-run debt series (1700 to present)",
      "encodingFormat": "application/json",
      "contentUrl": "https://raw.githubusercontent.com/LegendT/ukpublicfinances/main/src/_data/debtTimeseries.json"
    }
  ]
}
</script>

<div class="page-intro">
  <h1>{{ site.title }}</h1>
  <p class="lede">{{ site.tagline }}</p>
  <p class="updated">
    Latest figures for {{ dashboard.referencePeriod }}.
    Last updated {{ dashboard.lastUpdated | readableDate }}.
  </p>
</div>

<section aria-labelledby="headline-heading">
  <h2 id="headline-heading" class="visually-hidden">Headline figures</h2>
  <div class="metric-grid">
    {%- for metric in dashboard.metrics %}
      {%- if metric.display == "poundsShort" %}
        {% set formatted = metric.value | poundsShort %}
      {%- elif metric.display == "percentGdp" %}
        {% set formatted = metric.value + "% of GDP" %}
      {%- elif metric.display == "perPerson" %}
        {%- set netDebtBn = (dashboard.metrics | findBy("id", "net-debt")).value %}
        {%- set perPerson = (netDebtBn * 1000000000 / dashboard.supporting.population.value) | round(0) %}
        {% set formatted = "£" + (perPerson | number) %}
      {%- elif metric.display == "perYear" %}
        {% set formatted = "£" + (metric.value | number) + " bn / year" %}
      {%- elif metric.display == "billions" %}
        {% set formatted = "£" + (metric.value | oneDp) + " bn" %}
      {%- else %}
        {% set formatted = metric.value %}
      {%- endif %}
      {{ metricCard(metric, formatted, "metric-card--feature" if metric.id == "net-debt" else "") }}
    {%- endfor %}
  </div>
</section>

{{ caveatBox(dashboard.caveat, "About these figures") }}

<section class="next-steps" aria-labelledby="explore-heading">
  <h2 id="explore-heading">Explore further</h2>
  <ul class="card-links">
    <li><a href="{{ '/timeline/' | url }}"><strong>Historical timeline</strong><span>How debt has changed since 1700.</span></a></li>
    <li><a href="{{ '/debt-in-context/' | url }}"><strong>Debt in context</strong><span>Debt and interest next to annual spending.</span></a></li>
    <li><a href="{{ '/interest/' | url }}"><strong>Interest costs</strong><span>What servicing the debt costs each day.</span></a></li>
    <li><a href="{{ '/international/' | url }}"><strong>International comparison</strong><span>The UK next to other major economies.</span></a></li>
    <li><a href="{{ '/health/' | url }}"><strong>Public finance health</strong><span>A wider set of economic indicators.</span></a></li>
    <li><a href="{{ '/big-numbers/' | url }}"><strong>Big numbers translator</strong><span>Turn a large sum into per-person figures.</span></a></li>
    <li><a href="{{ '/lifetime/' | url }}"><strong>During your lifetime</strong><span>How debt has changed since you were born.</span></a></li>
    <li><a href="{{ '/budget-simulator/' | url }}"><strong>Budget simulator</strong><span>You are Chancellor: try the trade-offs.</span></a></li>
    <li><a href="{{ '/deficit-vs-debt/' | url }}"><strong>Debt vs deficit</strong><span>What the words actually mean.</span></a></li>
    <li><a href="{{ '/monthly/' | url }}"><strong>Monthly update</strong><span>The latest release in plain English.</span></a></li>
    <li><a href="{{ '/sources/' | url }}"><strong>Sources</strong><span>Where every figure comes from.</span></a></li>
  </ul>
</section>
