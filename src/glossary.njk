---
layout: layouts/base.njk
title: Glossary
description: Plain-English definitions of the key public-finance terms used across the site.
---
{% from "components/macros.njk" import glossaryTerm %}

<div class="page-intro prose">
  <h1>Glossary</h1>
  <p class="lede">Plain-English definitions of the terms used across this site.</p>
</div>

<dl class="glossary">
  {%- for term in glossary.terms %}
    {{ glossaryTerm(term) }}
  {%- endfor %}
</dl>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "UK public finance glossary",
  "url": "{{ site.url }}/glossary/",
  "hasDefinedTerm": [
    {%- for t in glossary.terms %}
    { "@type": "DefinedTerm", "name": {{ t.term | dump | safe }}, "description": {{ t.definition | dump | safe }} }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
